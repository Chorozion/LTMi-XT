{
  "name": "ltmi-xt-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "LTMi-XT — Layered Topological Memory Indexing — open release v0.1",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "reference/ts",
    "apps/cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "node --test --import tsx tests/smoke.test.mts",
    "ltmi": "node apps/cli/dist/main.js",
    "serve": "npm run build -w reference/ts && npm run build -w apps/cli && node apps/cli/dist/main.js serve",
    "clean": "rimraf reference/ts/dist apps/cli/dist"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://sophiaxt.com/research/ltmi-xt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chorozion/LTMi-XT.git"
  }
}
